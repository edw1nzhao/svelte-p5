{
  "name": "svelte-p5-viz",
  "version": "0.2.0",
  "description": "Visualization panel contract, registry, and scene-config types for svelte-p5. Composable, no-code-ready building blocks for canvas-based dashboards.",
  "keywords": [
    "svelte",
    "svelte5",
    "p5",
    "p5.js",
    "visualization",
    "dashboard",
    "panel",
    "no-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edw1nzhao/svelte-p5.git",
    "directory": "packages/viz"
  },
  "homepage": "https://github.com/edw1nzhao/svelte-p5/tree/main/packages/viz#readme",
  "bugs": {
    "url": "https://github.com/edw1nzhao/svelte-p5/issues"
  },
  "author": "Edwin Zhao",
  "license": "MIT",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "svelte-package -o dist && publint",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "p5": ">=1.11.0 <3",
    "svelte": "^5.0.0",
    "svelte-p5": "workspace:^"
  },
  "devDependencies": {
    "@sveltejs/package": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@types/p5": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "p5": "catalog:",
    "publint": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "svelte-p5": "workspace:*",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
