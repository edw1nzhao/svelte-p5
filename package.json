    "husky": "^9.1.7",
    "lint-staged": "^15.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte-eslint-parser": "^1.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
